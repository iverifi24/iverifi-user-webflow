rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User app: applicants doc id = Firebase Auth UID. User can read own doc (by uid or by email query) and write only own doc.
    match /applicants/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || resource.data.email == request.auth.token.email);
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
